# Groq API (required) — get free key at https://console.groq.com/keys
# Free tier: 30 req/min, 14,400 req/day, runs Llama 3.3 70B
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (optional fallback) — get free key at https://aistudio.google.com
GEMINI_API_KEY=

# Reddit API (optional, for sentiment analysis)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock_analyzer/0.1

# NewsAPI (optional) — get free key at https://newsapi.org
NEWSAPI_KEY=

# FRED API (optional) — get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# LLM Provider: "groq" (default), "gemini", or "ollama"
LLM_PROVIDER=groq

# Ollama settings (if using ollama as provider)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b
