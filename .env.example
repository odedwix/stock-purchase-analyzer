# Google Gemini API (required) — get free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Reddit API (optional, for sentiment analysis)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock_analyzer/0.1

# NewsAPI (optional) — get free key at https://newsapi.org
NEWSAPI_KEY=

# FRED API (optional) — get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# LLM Provider: "gemini" (default) or "ollama"
LLM_PROVIDER=gemini

# Ollama settings (if using ollama as provider)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b
