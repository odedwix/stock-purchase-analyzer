# Anthropic Claude API (recommended) — get key at https://console.anthropic.com
# Claude Haiku 4.5: fastest, ~$0.01 per analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM Provider: "anthropic" (recommended), "ollama" (free local), "groq", or "gemini"
LLM_PROVIDER=anthropic

# Ollama settings (free local alternative — no API key needed)
# Install: https://ollama.com, then: ollama pull qwen2.5:32b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# Groq API (alternative) — get free key at https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini API (alternative) — get free key at https://aistudio.google.com
GEMINI_API_KEY=

# Reddit API (optional, for sentiment analysis)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock_analyzer/0.1

# NewsAPI (optional) — get free key at https://newsapi.org
NEWSAPI_KEY=

# FRED API (optional) — get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
